# ─────────────────────────────────────────────────────────────────────────────
# Google Maps Scraper API — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Credentials ───────────────────────────────────────────────────────
# Path to your Google service account or OAuth2 client_secret JSON
GOOGLE_CREDENTIALS_FILE=credentials.json

# Your personal Gmail — every new spreadsheet is auto-shared with you
SHARE_WITH_EMAIL=your@gmail.com

# (Optional) Google Drive folder ID to organise all job spreadsheets
GOOGLE_DRIVE_FOLDER_ID=

# ── API Security ─────────────────────────────────────────────────────────────
# Secret key — set this to a long random string in production.
# Leave blank to disable auth (dev mode only!).
# Generate one:  python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=

# ── Server ───────────────────────────────────────────────────────────────────
# Port to listen on (Cloud Run sets this automatically)
PORT=8080

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for your frontend.
# Use * to allow all origins (dev only).
# Example: ALLOWED_ORIGINS=https://myfrontend.com,https://admin.myfrontend.com
ALLOWED_ORIGINS=*
